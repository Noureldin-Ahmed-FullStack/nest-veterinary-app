generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email       String  @unique
  name        String
  password    String
  description String?
  posts       Post[]
  pets       Pet[]
  role     Role   @default(USER)
  dateCreated DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @db.Timestamptz(6)
}
model Pet {
  id        String @id @default(uuid())
  name     String
  age  Int
  pfp  String?
  type   String
  breed   String
  ownerId  String?
  owner    User?   @relation(fields: [ownerId], references: [id])
  dateCreated DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @db.Timestamptz(6)
}


enum Role {
  USER
  ADMIN
}

model Post {
  id        String @id @default(uuid())
  title     String
  authorId  String?
  content   String?
  author    User?   @relation(fields: [authorId], references: [id])
  dateCreated DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @db.Timestamptz(6)
}
