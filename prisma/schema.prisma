generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  name        String
  password    String
  description String?
  posts       Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  published Boolean @default(false)
  authorId  Int?
  content   String?
  author    User?   @relation(fields: [authorId], references: [id])
}
